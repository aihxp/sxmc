{
  "name": "@aihxp/sxmc",
  "version": "0.1.4",
  "description": "Thin npm wrapper for the sxmc Rust CLI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aihxp/sxmc.git"
  },
  "homepage": "https://github.com/aihxp/sxmc",
